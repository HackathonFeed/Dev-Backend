# ============================================================================
# HackathonFeed Backend Environment Configuration
# ============================================================================

# Application
APP_NAME=HackathonFeed API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database – Supabase direct connection
# Raw password: HackathonFeedSourceData@#$
# URL-encoded: @=%40  #=%23  $=%24
DATABASE_URL=postgresql+asyncpg://postgres:HackathonFeedSourceData%40%23%24@db.yxjeyplqbftoerfrrxqp.supabase.co:5432/postgres

# Optional: Session pooler (IPv4) – copy exact host from Dashboard > Connect > Session pooler
# DATABASE_POOLER_URL=postgresql+asyncpg://postgres.yxjeyplqbftoerfrrxqp:HackathonFeedSourceData%40%23%24@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=534463940339-180t7uvp26jqhkc4aqagn7tpoo6iibin.apps.googleusercontent.com

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Supabase REST (service role key – same project as DATABASE_URL)
SUPABASE_URL=https://yxjeyplqbftoerfrrxqp.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_KEY=your-service-role-key
USE_SUPABASE_HACKATHONS=true
PREFER_SUPABASE_REST=true

# ── AI / AWS Bedrock ──────────────────────────────────────────────────────────
# Nova Micro  = amazon.nova-micro-v1:0  (cheapest, text-only)
# Nova Lite   = amazon.nova-lite-v1:0   (multimodal)
# Nova Pro    = amazon.nova-pro-v1:0    (most capable)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# ── Razorpay Payment Pages (Option 3 — hosted checkout) ─────────────────────
# Create pages in Razorpay Dashboard → Payment Pages (Builder ₹299, Champion ₹499)
# Paste the shareable page URLs below. Upgrades are applied via webhook.
RAZORPAY_PAYMENT_PAGE_BUILDER_URL=https://rzp.io/rzp/LlsB8Jz8
RAZORPAY_PAYMENT_PAGE_CHAMPION_URL=https://rzp.io/rzp/m8Cj824Y
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_dashboard
FRONTEND_URL=https://www.hackathonfeed.com

# Required for claim-upgrade fallback (lists/fetches payments from Razorpay API)
# Optional — only needed for legacy embedded Checkout (not Payment Pages)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── SMTP (Gmail) — works locally; blocked on Vercel serverless
# Use Resend HTTP API in production (see RESEND_* below)
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=HackathonFeed

# Resend (recommended for Vercel) — https://resend.com
RESEND_API_KEY=re_your_api_key
RESEND_FROM=HackathonFeed <noreply@hackathonfeed.com>
