# ============================================================================
# HackathonFeed Backend Environment Configuration
# ============================================================================

# Application
APP_NAME=HackathonFeed API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database – Supabase direct connection
# Raw password: HackathonFeedSourceData@#$
# URL-encoded: @=%40  #=%23  $=%24
DATABASE_URL=postgresql+asyncpg://postgres:HackathonFeedSourceData%40%23%24@db.yxjeyplqbftoerfrrxqp.supabase.co:5432/postgres

# Optional: Session pooler (IPv4) – copy exact host from Dashboard > Connect > Session pooler
# DATABASE_POOLER_URL=postgresql+asyncpg://postgres.yxjeyplqbftoerfrrxqp:HackathonFeedSourceData%40%23%24@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=534463940339-180t7uvp26jqhkc4aqagn7tpoo6iibin.apps.googleusercontent.com

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Supabase REST (service role key – same project as DATABASE_URL)
SUPABASE_URL=https://yxjeyplqbftoerfrrxqp.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_KEY=your-service-role-key
USE_SUPABASE_HACKATHONS=true
PREFER_SUPABASE_REST=true
